# Production / shared template. For local dev, copy .env.local.example → .env.local
#
# Supabase — Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App — use www if that is your canonical domain on Vercel
NEXT_PUBLIC_SITE_URL=https://www.hyperank.ca
CRON_SECRET=generate-with-openssl-rand-hex-32
ADMIN_USER_ID=your-supabase-user-uuid

# Email
RESEND_API_KEY=

# Rate limiting (optional)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Features
NEXT_PUBLIC_COOKIE_BANNER=true
CONTACT_EMAIL=legal@hyperank.ca
